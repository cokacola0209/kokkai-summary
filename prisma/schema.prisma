generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ──────────────────────────────────────────
// 既存テーブル
// ──────────────────────────────────────────

model Meeting {
  id            String   @id @default(cuid())
  ndlId         String   @unique
  date          DateTime @db.Date
  house         String
  nameOfMeeting String
  issue         String?
  url           String
  rawJson       Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  speeches      Speech[]
  summary       Summary?
  @@index([date])
  @@index([house])
}

model Speech {
  id           String  @id @default(cuid())
  meetingId    String
  speaker      String            // raw値を保持
  speakerGroup String?           // raw値を保持
  order        Int
  text         String

  // ── 追加: 正規化リレーション（nullable → 段階的にバックフィル） ──
  personId     String?
  partyId      String?

  meeting      Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  person       Person?  @relation(fields: [personId], references: [id])
  party        Party?   @relation(fields: [partyId], references: [id])

  @@index([meetingId])
  @@index([personId])
  @@index([partyId])
}

model Summary {
  id               String   @id @default(cuid())
  meetingId        String   @unique
  bullets          String[]
  keyTopics        String[]
  agreementPoints  String[]
  conflictPoints   String[]
  impactNotes      String[]
  speakerSummaries Json     @default("[]")
  sourceLinks      String[]
  modelUsed        String   @default("unknown")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  meeting          Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
}

model FetchLog {
  id        String   @id @default(cuid())
  date      DateTime @db.Date
  status    String
  fetched   Int      @default(0)
  errors    String[]
  createdAt DateTime @default(now())
  @@index([date])
}

// ──────────────────────────────────────────
// 新規: 政党・会派
// ──────────────────────────────────────────

model Party {
  id        String   @id @default(cuid())
  name      String   @unique       // 正式名称 例: "自由民主党・無所属の会"
  shortName String                 // 略称 例: "自民"
  color     String   @default("#6b7280") // UI表示用カラーコード
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  speeches  Speech[]
  persons   Person[]
  seats     PartySeat[]
}

// ──────────────────────────────────────────
// 新規: 議席数（院×会派ごと、時点管理）
// ──────────────────────────────────────────

model PartySeat {
  id        String   @id @default(cuid())
  partyId   String
  house     String                 // "衆議院" | "参議院"
  seats     Int                    // 議席数
  asOf      DateTime @db.Date      // いつ時点の数字か
  createdAt DateTime @default(now())

  party     Party    @relation(fields: [partyId], references: [id], onDelete: Cascade)

  @@unique([partyId, house, asOf])
  @@index([house, asOf])
}

// ──────────────────────────────────────────
// 新規: 人物
// ──────────────────────────────────────────

model Person {
  id        String   @id @default(cuid())
  name      String   @unique       // 正規化名 例: "石破茂"
  aliases   String[]               // 表記ゆれ吸収 例: ["石破　茂", "石破茂君"]
  partyId   String?                // 現在の所属（補助情報、履歴はSpeech.partyIdが正）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  party     Party?   @relation(fields: [partyId], references: [id])
  speeches  Speech[]

  @@index([partyId])
}
// ──────────────────────────────────────────
// 新規: 管理者まとめ（日次編集メモ）
// ──────────────────────────────────────────

model DailyEditorNote {
  id               String   @id @default(cuid())
  targetDate       DateTime @unique @db.Date
  title            String   @default("")
  introText        String   @default("")
  aiDraft          String   @default("")
  editedText       String   @default("")
  status           String   @default("draft")       // draft | reviewed | published
  suggestedPoints  String[] @default([])
  generatedAt      DateTime?
  publishedAt      DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
