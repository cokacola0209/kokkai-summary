# .env.example
# ─────────────────────────────────────────────────
# データベース
# ─────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/kokkai_summary"

# ─────────────────────────────────────────────────
# NDL 国会会議録検索システム API
# (API キー不要。公開 API)
# ─────────────────────────────────────────────────
NDL_API_BASE_URL="https://kokkai.ndl.go.jp/api"
# リクエスト間隔 (ms) ※NDL 推奨: 1秒以上
NDL_RATE_LIMIT_MS="1200"
# リトライ回数
NDL_MAX_RETRIES="3"

# ─────────────────────────────────────────────────
# LLM プロバイダ設定
# LLM_PROVIDER: "openai" | "anthropic" | "stub"
# ─────────────────────────────────────────────────
LLM_PROVIDER="openai"

# OpenAI
OPENAI_API_KEY="sk-..."
# 推奨モデル: gpt-4o (精度優先) / gpt-4o-mini (コスト優先)
OPENAI_MODEL="gpt-4o-mini"

# Anthropic (LLM_PROVIDER="anthropic" の場合)
ANTHROPIC_API_KEY="sk-ant-..."
ANTHROPIC_MODEL="claude-3-5-haiku-20241022"

# ─────────────────────────────────────────────────
# サイト設定
# ─────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="https://your-domain.com"
